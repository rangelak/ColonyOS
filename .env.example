# =============================================================================
# ColonyOS Docker Environment Variables
# =============================================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
# =============================================================================

# ---------------------------------------------------------------------------
# Required
# ---------------------------------------------------------------------------

# Anthropic API key for Claude agent execution
ANTHROPIC_API_KEY=sk-ant-...

# GitHub personal access token (required for PR creation, issue management)
GH_TOKEN=ghp_...

# ---------------------------------------------------------------------------
# Optional — Repository
# ---------------------------------------------------------------------------

# If set and /workspace is empty, the entrypoint will clone this repo on start
# COLONYOS_REPO_URL=https://github.com/your-org/your-repo.git

# ---------------------------------------------------------------------------
# Optional — Telemetry (PostHog)
# ---------------------------------------------------------------------------

# COLONYOS_POSTHOG_API_KEY=phc_...
# COLONYOS_POSTHOG_HOST=https://us.i.posthog.com

# ---------------------------------------------------------------------------
# Optional — Slack Integration
# ---------------------------------------------------------------------------

# COLONYOS_SLACK_BOT_TOKEN=xoxb-...
# COLONYOS_SLACK_APP_TOKEN=xapp-...

# ---------------------------------------------------------------------------
# Optional — Dashboard
# ---------------------------------------------------------------------------

# Enable write endpoints (config editing, run launching) on the dashboard
# COLONYOS_WRITE_ENABLED=1
