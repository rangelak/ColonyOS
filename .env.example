# Preferred: Azure OpenAI configuration
AZURE_OPENAI_API_KEY=your-azure-key-here
AZURE_OPENAI_ENDPOINT=https://your-resource-name.cognitiveservices.azure.com/
AZURE_OPENAI_MODEL=gpt-5.4-pro
# Default Azure Responses API version used by this repo is 2025-03-01-preview.
# Optional: override it only if your deployment requires a newer supported version.
# AZURE_OPENAI_API_VERSION=2025-03-01-preview

# Optional: non-Azure OpenAI fallback
# OPENAI_API_KEY=sk-your-key-here

# Optional: force a specific model regardless of provider defaults
# COLONYOS_MODEL=gpt-5.4
